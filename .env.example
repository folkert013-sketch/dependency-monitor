# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True

# LLM - Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# Microsoft Graph API (email)
MS_GRAPH_TENANT_ID=your-azure-tenant-id
MS_GRAPH_CLIENT_ID=your-azure-client-id
MS_GRAPH_CLIENT_SECRET=your-azure-client-secret
MS_GRAPH_USER_ID=your-email@yourdomain.com
EMAIL_TO=your-email@yourdomain.com

# Monitored project path
MONITORED_PROJECT_PATH=/path/to/your/project

# Email tracking (local)
TRACKING_BASE_URL=http://localhost:8001

# GitHub (optional, for higher rate limits)
GITHUB_TOKEN=
